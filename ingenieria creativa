<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --navy:  #0a1628; --navy2: #0f1f3d; --navy3: #152848;
  --green: #2ecc71; --green2:#27ae60;
  --gold:  #c9a84c; --gold2: #e8c96a;
  --white: #f0f4f8; --muted: #8ba3c4;
  --card:  rgba(15,31,61,0.9);
}
html { scroll-behavior: smooth; }
body { font-family:'DM Sans',sans-serif; background:var(--navy); color:var(--white); overflow-x:hidden; }

/* NAV */
nav { position:fixed; top:0; width:100%; z-index:100; padding:.9rem 2.5rem; display:flex; align-items:center; justify-content:space-between; background:rgba(10,22,40,.95); backdrop-filter:blur(14px); border-bottom:1px solid rgba(46,204,113,.15); }
.nav-logo { display:flex; align-items:center; gap:12px; text-decoration:none; }
.nav-logo img { width:42px; height:42px; border-radius:50%; border:2px solid var(--green); object-fit:cover; }
.nav-brand { font-family:'Bebas Neue',sans-serif; font-size:1.3rem; letter-spacing:2px; color:var(--white); }
.nav-links { display:flex; gap:1.8rem; list-style:none; }
.nav-links a { color:var(--muted); text-decoration:none; font-size:.82rem; font-weight:500; letter-spacing:1px; text-transform:uppercase; transition:color .3s; }
.nav-links a:hover { color:var(--green); }
.nav-cta { background:var(--green); color:var(--navy); padding:.5rem 1.3rem; border-radius:4px; font-weight:700; font-size:.82rem; text-decoration:none; letter-spacing:1px; text-transform:uppercase; transition:background .3s; }
.nav-cta:hover { background:var(--green2); }

/* HERO */
.hero { min-height:100vh; position:relative; display:flex; align-items:center; overflow:hidden; }
.hero-bg { position:absolute; inset:0; background:linear-gradient(135deg,#0a1628 0%,#0f2340 55%,#0a1628 100%); }
.hero-grid { position:absolute; inset:0; opacity:.035; background-image:linear-gradient(var(--green) 1px,transparent 1px),linear-gradient(90deg,var(--green) 1px,transparent 1px); background-size:60px 60px; }
.hero-glow { position:absolute; width:700px; height:700px; border-radius:50%; background:radial-gradient(circle,rgba(46,204,113,.07) 0%,transparent 70%); top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none; }
.hero-inner { position:relative; z-index:2; max-width:1140px; margin:0 auto; padding:8rem 2rem 5rem; display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; width:100%; }
.hero-text { animation:fadeUp .8s ease both; }
.hero-badge { display:inline-flex; align-items:center; gap:8px; background:rgba(46,204,113,.1); border:1px solid rgba(46,204,113,.3); color:var(--green); padding:.4rem 1rem; border-radius:20px; font-size:.75rem; font-weight:600; letter-spacing:2px; text-transform:uppercase; margin-bottom:1.5rem; }
.hero-badge::before { content:''; width:6px; height:6px; background:var(--green); border-radius:50%; animation:pulse 2s infinite; }
.hero-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(3.5rem,7vw,6rem); line-height:.92; letter-spacing:3px; margin-bottom:.5rem; }
.hero-title span { color:var(--green); }
.hero-slogan { font-size:1rem; color:var(--muted); margin:1.5rem 0 2.5rem; line-height:1.65; max-width:420px; border-left:3px solid var(--gold); padding-left:1rem; }
.hero-btns { display:flex; gap:1rem; flex-wrap:wrap; }
.btn-green { background:var(--green); color:var(--navy); padding:.85rem 2rem; border-radius:4px; font-weight:700; font-size:.88rem; text-decoration:none; letter-spacing:1px; text-transform:uppercase; transition:all .3s; display:inline-block; border:none; cursor:pointer; }
.btn-green:hover { background:var(--green2); transform:translateY(-2px); }
.btn-gold { border:1.5px solid var(--gold); color:var(--gold); padding:.85rem 2rem; border-radius:4px; font-weight:600; font-size:.88rem; text-decoration:none; letter-spacing:1px; text-transform:uppercase; transition:all .3s; display:inline-block; background:transparent; }
.btn-gold:hover { background:rgba(201,168,76,.1); transform:translateY(-2px); }
.hero-visual { animation:fadeUp 1s .2s ease both; }
.hero-banner { position:relative; border-radius:12px; overflow:hidden; border:1px solid rgba(46,204,113,.25); box-shadow:0 0 70px rgba(46,204,113,.1); }
.hero-banner img { width:100%; display:block; object-fit:cover; }
.hero-fade { position:absolute; bottom:0; left:0; right:0; height:40%; background:linear-gradient(transparent,rgba(10,22,40,.88)); }

/* STATS */
.stats { background:var(--navy2); border-top:1px solid rgba(46,204,113,.1); border-bottom:1px solid rgba(46,204,113,.1); padding:2.2rem 2rem; }
.stats-inner { max-width:1140px; margin:0 auto; display:grid; grid-template-columns:repeat(4,1fr); gap:2rem; text-align:center; }
.stat-n { font-family:'Bebas Neue',sans-serif; font-size:2.8rem; color:var(--green); letter-spacing:2px; line-height:1; }
.stat-l { font-size:.76rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-top:4px; }

/* SECTIONS */
section { padding:5.5rem 2rem; }
.sec { max-width:1140px; margin:0 auto; }
.sec-tag { color:var(--green); font-size:.75rem; letter-spacing:3px; text-transform:uppercase; font-weight:600; margin-bottom:.9rem; }
.sec-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(2.5rem,5vw,4rem); letter-spacing:3px; line-height:1; margin-bottom:.9rem; }
.sec-title span { color:var(--green); }
.sec-sub { color:var(--muted); max-width:500px; line-height:1.7; margin-bottom:3.5rem; }

/* SERVICIOS */
.sv-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:1.5rem; }
.sv-card { background:var(--card); border:1px solid rgba(46,204,113,.12); border-radius:10px; padding:2rem; transition:all .3s; position:relative; overflow:hidden; }
.sv-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,var(--green),var(--gold)); transform:scaleX(0); transform-origin:left; transition:transform .3s; }
.sv-card:hover { border-color:rgba(46,204,113,.4); transform:translateY(-5px); }
.sv-card:hover::before { transform:scaleX(1); }
.sv-icon { font-size:2rem; margin-bottom:1rem; }
.sv-name { font-family:'Bebas Neue',sans-serif; font-size:1.4rem; letter-spacing:2px; margin-bottom:.7rem; }
.sv-desc { color:var(--muted); font-size:.87rem; line-height:1.65; }

/* POR QUÉ */
.why-bg { background:var(--navy2); }
.why-grid { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; }
.why-logo-wrap { display:flex; align-items:center; justify-content:center; }
.logo-ring { width:290px; height:290px; border-radius:50%; border:2px solid rgba(46,204,113,.3); padding:16px; position:relative; }
.logo-ring::before { content:''; position:absolute; inset:-10px; border-radius:50%; border:1px solid rgba(201,168,76,.2); }
.logo-ring img { width:100%; height:100%; border-radius:50%; object-fit:cover; }
.reasons { display:flex; flex-direction:column; gap:1.5rem; }
.reason { display:flex; gap:1rem; align-items:flex-start; }
.r-icon { width:44px; height:44px; border-radius:8px; flex-shrink:0; background:rgba(46,204,113,.1); border:1px solid rgba(46,204,113,.2); display:flex; align-items:center; justify-content:center; font-size:1.2rem; }
.r-title { font-weight:700; font-size:.95rem; margin-bottom:4px; }
.r-text { color:var(--muted); font-size:.85rem; line-height:1.6; }

/* PROCESO */
.proc-row { display:grid; grid-template-columns:repeat(4,1fr); }
.p-step { padding:2rem; border-right:1px solid rgba(46,204,113,.1); }
.p-step:last-child { border-right:none; }
.p-num { font-family:'Bebas Neue',sans-serif; font-size:4rem; color:rgba(46,204,113,.1); line-height:1; margin-bottom:.4rem; }
.p-title { font-weight:700; margin-bottom:.4rem; }
.p-desc { color:var(--muted); font-size:.84rem; line-height:1.6; }

/* REFERENCIAS */
.refs-bg { background:var(--navy2); }
.refs-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:10px; margin-bottom:3rem; }
.ref-img { border-radius:8px; overflow:hidden; aspect-ratio:9/14; border:1px solid rgba(46,204,113,.12); transition:all .3s; }
.ref-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .4s; }
.ref-img:hover { border-color:rgba(46,204,113,.45); transform:translateY(-4px); }
.ref-img:hover img { transform:scale(1.04); }
.refs-sub-title { font-family:'Bebas Neue',sans-serif; font-size:1.6rem; letter-spacing:2px; margin-bottom:1.2rem; }
.refs-videos { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.2rem; margin-bottom:3rem; }
.vid-wrap { border-radius:10px; overflow:hidden; border:1px solid rgba(46,204,113,.15); aspect-ratio:16/9; background:var(--navy3); display:flex; align-items:center; justify-content:center; }
.vid-ph { text-align:center; color:var(--muted); }
.vid-ph span { font-size:2.5rem; display:block; margin-bottom:.5rem; }
.vid-ph p { font-size:.82rem; }
.ref-lp { background:var(--card); border:1px solid rgba(46,204,113,.2); border-radius:12px; padding:2rem; display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
.ref-lp-tag { display:inline-block; background:rgba(46,204,113,.12); border:1px solid rgba(46,204,113,.3); color:var(--green); font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem .8rem; border-radius:20px; margin-bottom:.8rem; }
.ref-lp h3 { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:2px; margin-bottom:.5rem; }
.ref-lp p { color:var(--muted); font-size:.88rem; max-width:420px; line-height:1.6; }

/* CTA */
.cta-bg { background:linear-gradient(135deg,var(--navy2),var(--navy3)); border-top:1px solid rgba(46,204,113,.15); border-bottom:1px solid rgba(46,204,113,.15); text-align:center; }
.cta-bg .sec-sub { margin:0 auto 2.5rem; }
.social-row { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:2.5rem; }
.soc-btn { display:flex; align-items:center; gap:8px; padding:.65rem 1.4rem; border-radius:8px; font-weight:600; font-size:.85rem; text-decoration:none; transition:all .3s; border:1px solid; }
.soc-fb  { background:rgba(24,119,242,.1);  border-color:rgba(24,119,242,.35);  color:#5b9cf6; }
.soc-ig  { background:rgba(228,64,95,.1);   border-color:rgba(228,64,95,.35);   color:#f4799a; }
.soc-tt  { background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.2);  color:#e8e8e8; }
.soc-wa  { background:rgba(37,211,102,.1);  border-color:rgba(37,211,102,.35);  color:#25d366; }
.soc-btn:hover { transform:translateY(-3px); filter:brightness(1.15); }

/* FOOTER */
footer { background:#050d1a; padding:2.5rem 2rem; text-align:center; border-top:1px solid rgba(46,204,113,.08); }
.ft-logo { display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:1rem; }
.ft-logo img { width:38px; height:38px; border-radius:50%; border:1.5px solid var(--green); object-fit:cover; }
.ft-brand { font-family:'Bebas Neue',sans-serif; font-size:1.4rem; letter-spacing:3px; }
.ft-line { width:50px; height:2px; background:var(--green); margin:.8rem auto 1rem; }
.ft-slogan { color:var(--muted); font-size:.8rem; letter-spacing:2px; text-transform:uppercase; }
.ft-copy { color:rgba(139,163,196,.35); font-size:.72rem; margin-top:1.5rem; }

@keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
@keyframes pulse  { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.8)} }

@media(max-width:900px){
  .hero-inner  { grid-template-columns:1fr; gap:2.5rem; padding-top:6rem; }
  .hero-visual { order:-1; }
  .why-grid    { grid-template-columns:1fr; }
  .why-logo-wrap { display:none; }
  .proc-row    { grid-template-columns:1fr 1fr; }
  .p-step      { border-right:none; border-bottom:1px solid rgba(46,204,113,.1); }
  .p-step:last-child { border-bottom:none; }
}
@media(max-width:600px){
  .stats-inner { grid-template-columns:repeat(2,1fr); }
  .nav-links   { display:none; }
  .proc-row    { grid-template-columns:1fr; }
  .refs-grid   { grid-template-columns:repeat(2,1fr); }
}
</style>
</head>
